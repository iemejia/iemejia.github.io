{
  "name": "iemejia-site-tests",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end tests for the site (navigation, links, etc.)",
  "scripts": {
    "validate": "hugo --printPathWarnings && playwright test",
    "test": "playwright test",
    "test:a11y": "playwright test tests/accessibility.spec.js",
    "test:ui": "playwright test --ui",
    "test:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.48.0"
  }
}
